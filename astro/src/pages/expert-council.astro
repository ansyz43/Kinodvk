---
import Layout from "../layouts/Layout.astro";

const slots = [
  { num: "01", role: "Председатель совета", note: "Кинокритик / куратор фестивальной программы" },
  { num: "02", role: "Игровое кино",        note: "Режиссёр / продюсер региональных проектов" },
  { num: "03", role: "Неигровое кино",      note: "Документалист, опыт работы с ДВ-материалом" },
  { num: "04", role: "Анимация",            note: "Художник или продюсер анимационных проектов" },
  { num: "05", role: "Короткий метр",       note: "Опыт фестивального отбора короткого метра" },
  { num: "06", role: "Региональная экспертиза", note: "Журналист или киновед, специалист по ДВ" },
  { num: "07", role: "Индустрия Арктики",   note: "Спец. член совета — для новой номинации 2026" },
];
---
<Layout title={`Экспертный совет · Дальневосточная Кинопремия 2026`} active={"expert-council"}>

<section class="page-hero v2">
  <div class="page-hero-eyebrow"><span class="dot"></span><span>Экспертный совет</span></div>
  <h1 class="page-hero-title" data-text-reveal>Кто <em>отбирает</em> фильмы</h1>
  <p class="page-hero-lead">Состав совета будет опубликован после утверждения оргкомитетом. Здесь — структура и&nbsp;области экспертизы каждого слота. В&nbsp;2026 году добавлен новый слот — Арктика.</p>
</section>

<section class="people-list reveal-stagger">
  {slots.map((s) => (
    <article class="people-row">
      <div class="people-row-num">{s.num}</div>
      <div class="people-row-body">
        <div class="people-row-role">{s.role}</div>
        <h3 class="people-row-name">Будет объявлено</h3>
        <div class="people-row-note">{s.note}</div>
      </div>
      <div class="people-row-tag">Сезон 2026</div>
    </article>
  ))}
</section>

</Layout>
