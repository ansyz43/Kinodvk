---
import Layout from "../layouts/Layout.astro";

const rules = [
  { num: "01", title: "Кто может подать", body: "Продюсеры, режиссёры, правообладатели полнометражных и&nbsp;короткометражных фильмов и&nbsp;сериалов. Иностранные участники — только при&nbsp;наличии русскоязычной версии или&nbsp;субтитров." },
  { num: "02", title: "Что принимается", body: "Игровые, неигровые и&nbsp;анимационные работы, связанные с&nbsp;Дальневосточным федеральным округом — снятые в&nbsp;регионе или&nbsp;рассказывающие о&nbsp;нём." },
  { num: "03", title: "Сроки", body: "Приём заявок — апрель–июнь 2026. Шорт-листы — конец июля. Финальное голосование — август. Церемония — 25&nbsp;сентября в&nbsp;Хабаровске." },
  { num: "04", title: "Хронометраж", body: "Полный метр: от&nbsp;60&nbsp;минут (игровое), от&nbsp;52&nbsp;минут (неигровое). Короткий метр — до&nbsp;60&nbsp;минут / 52&nbsp;минут соответственно." },
  { num: "05", title: "Технические требования", body: "Платформа-агрегатор будет объявлена в&nbsp;апреле. Альтернатива — прямая отправка ссылок на&nbsp;трейлер и&nbsp;онлайн-версию через форму на&nbsp;сайте." },
  { num: "06", title: "Сборы", body: "Подача заявок — бесплатно. Никаких регистрационных взносов или&nbsp;скрытых платежей." },
];
---
<Layout title={`Регламент · Дальневосточная Кинопремия 2026`} active={"regulation"}>

<section class="page-hero v2">
  <div class="page-hero-eyebrow"><span class="dot"></span><span>Регламент</span></div>
  <h1 class="page-hero-title" data-text-reveal>Правила <em>подачи</em></h1>
  <p class="page-hero-lead">Кто может подать, что принимается, когда, в&nbsp;каком формате. Полный регламент будет опубликован в&nbsp;апреле 2026, до&nbsp;старта приёма заявок.</p>
</section>

<section class="rules-list reveal-stagger">
  {rules.map((r) => (
    <article class="rule-row">
      <div class="rule-row-num">{r.num}</div>
      <div class="rule-row-body">
        <h3 class="rule-row-title">{r.title}</h3>
        <p class="rule-row-text" set:html={r.body}></p>
      </div>
    </article>
  ))}
</section>

</Layout>
